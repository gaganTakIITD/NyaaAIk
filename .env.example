# Copy to .env for local dev only — never commit .env
# Prefer Databricks secret scope `nyaya-dhwani` in the workspace.

DATAGOV_API_KEY=
SARVAM_API_KEY=
# Optional for RAG / LLM (see docs/PLAYGROUND_TO_APP.md)
# OPENAI_API_KEY=
# DATABRICKS_TOKEN=
# LLM_OPENAI_BASE_URL=https://<workspace-id>.ai-gateway.cloud.databricks.com/mlflow/v1
# LLM_CHAT_COMPLETIONS_URL=
# LLM_MODEL=
# GROQ_API_KEY=

# Vector Search backend (optional — falls back to FAISS if unavailable)
# NYAYA_RETRIEVAL_BACKEND=vector_search
# NYAYA_VS_ENDPOINT_NAME=nyaya_vs_endpoint
# NYAYA_VS_INDEX_NAME=main.india_legal.legal_rag_corpus_index

# HuggingFace token (for BhashaBench-Legal benchmark dataset)
# Also stored in Databricks secret scope: nyaya-dhwani/hf_token
# HF_TOKEN=

# Live precedent case search (see src/nyaya_dhwani/case_search.py)
INDIAN_KANOON_API_TOKEN=
# Google Custom Search Engine (backup for Indian Kanoon)
GOOGLE_API_KEY=
GOOGLE_CSE_CX=
